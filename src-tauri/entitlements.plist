<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Microphone access for recording -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
  <!-- Apple Events (required for CGEvent injection) -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
  <!-- Hardened runtime: allow unsigned executable memory (whisper.cpp needs this in v2) -->
  <!-- <key>com.apple.security.cs.allow-unsigned-executable-memory</key> -->
  <!-- <true/> -->
  <!--
    NOTE: App Sandbox is intentionally NOT enabled.
    CGEventTap (global hotkey monitoring) and CGEvent injection (Smart Paste)
    are incompatible with the App Sandbox. This app must be distributed
    outside the Mac App Store.
  -->
</dict>
</plist>
